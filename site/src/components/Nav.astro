---
import SearchBar from './SearchBar.astro';

const currentPath = Astro.url.pathname;
const isHomepage = currentPath === '/';
const navLinks = [
  { href: '/return-policies/', label: 'Return Policies' },
  { href: '/cancellation-policies/', label: 'Cancellation Policies' },
  { href: '/credit-card-agreements/', label: 'Credit Cards' },
  { href: '/warranty-fine-print/', label: 'Warranties' },
];
---

<header class="site-header">
  <nav class="site-nav">
    <div class="container">
      <a href="/" class="site-nav__logo">FinePrintDecoder</a>
      <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">&#9776;</button>
      <ul class="site-nav__links" id="nav-links">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  {!isHomepage && (
    <div class="site-search">
      <div class="container">
        <SearchBar variant="nav" />
      </div>
    </div>
  )}
</header>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const links = document.getElementById('nav-links');
  if (toggle && links) {
    toggle.addEventListener('click', () => {
      const open = links.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(open));
    });
  }
</script>
