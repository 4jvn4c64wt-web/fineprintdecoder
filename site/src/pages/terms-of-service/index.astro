---
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
  { slug: 'amazon', name: 'Amazon', subtitle: 'Conditions of Use', ready: true },
  { slug: 'amazon-privacy', name: 'Amazon', subtitle: 'Privacy Notice', ready: true },
  { slug: 'openai', name: 'OpenAI', subtitle: 'Terms of Service', ready: false },
  { slug: 'uber', name: 'Uber', subtitle: 'Terms of Service', ready: false },
  { slug: 'airbnb', name: 'Airbnb', subtitle: 'Terms of Service', ready: false },
  { slug: 'venmo', name: 'Venmo', subtitle: 'User Agreement', ready: false },
];
---

<BaseLayout title="Terms of Service" description="The rights you're giving up by clicking 'I agree' — key clauses decoded.">
  <div class="container">
    <div class="category-header">
      <h1>Terms of Service</h1>
      <p>The rights you're giving up by clicking "I agree."</p>
    </div>

    <div class="card-grid">
      {services.map(item => (
        <a href={`/terms-of-service/${item.slug}/`} class="card">
          <h3>{item.name} {item.subtitle}</h3>
          <p>{item.ready ? 'Decoded — read the plain-English summary.' : 'Summary coming soon.'}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
