---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CompareWidget from '../../components/CompareWidget.astro';

const services = [
  { slug: 'openai', name: 'OpenAI' },
  { slug: 'uber', name: 'Uber' },
  { slug: 'airbnb', name: 'Airbnb' },
  { slug: 'venmo', name: 'Venmo' },
];
---

<BaseLayout title="Terms of Service" description="Plain-English summaries of the clauses in major terms of service that affect everyday users — arbitration, account termination, content rights, and similar.">
  <div class="container">
    <div class="category-header">
      <h1>Terms of Service</h1>
      <p>The clauses in a terms of service that actually affect you: arbitration, account termination, content licenses, and dispute venue.</p>
    </div>

    <CompareWidget category="terms-of-service" categoryLabel="Terms of Service" />

    <div class="card-grid">
      {services.map(item => (
        <a href={`/terms-of-service/${item.slug}/`} class="card">
          <h3>{item.name} Terms of Service</h3>
          <p>Summary coming soon.</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
