---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';
import MerchantCarousel from '../components/MerchantCarousel.astro';
import { getCollection } from 'astro:content';

// Browse-by-category cards. "Terms of Service" intentionally not included — vendor-level
// legal content lives on merchant overviews (/[vendorSlug]/), not on a TOS category page.
const categories = [
  {
    href: '/return-policies/',
    title: 'Return Policies',
    description: 'How long you have, what you need, what gets refunded.',
  },
  {
    href: '/cancellation-policies/',
    title: 'Cancellation Policies',
    description: 'How to actually cancel, what it costs, and how long it takes.',
  },
  {
    href: '/credit-card-agreements/',
    title: 'Credit Card Agreements',
    description: 'Annual fee, APR, foreign transaction fees, and the conditions on the rewards.',
  },
  {
    href: '/warranty-fine-print/',
    title: 'Warranty Fine Print',
    description: 'What is covered, what is excluded, and how to file a claim.',
  },
];

// Popular Summaries — manually curated short list of high-value policy summaries.
// As the published count grows, swap to traffic-driven selection. For now, show whatever
// is published from this curated set; skip the ones we haven't decoded yet.
const popularList = [
  { vendorSlug: 'amazon', category: 'return-policies' },
  { vendorSlug: 'amazon', category: 'cancellation-policies' },        // Amazon Prime cancellation
  { vendorSlug: 'amazon', category: 'terms-of-service' },             // Prime Video TOS
];

const allPolicies = await getCollection('policies');
const popularSummaries = popularList
  .map(({ vendorSlug, category }) => {
    return allPolicies.find((p) => p.data.vendorSlug === vendorSlug && p.data.category === category);
  })
  .filter((p): p is NonNullable<typeof p> => Boolean(p))
  .map((p) => {
    const cleanId = p.id.replace(/\.md$/, '');
    const [cat, ...rest] = cleanId.split('/');
    return {
      href: `/${cat}/${rest.join('/')}/`,
      title: `${p.data.company} ${p.data.policyType}`,
      summary: p.data.summary,
    };
  });
---

<BaseLayout title="We read the fine print so you don't have to">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1>We read the fine print so you don't have to.</h1>
      <p>Plain-English summaries of return policies, cancellation terms, credit card agreements, warranties, and terms of service. Each summary links back to the source document.</p>

      <div class="hero__search">
        <SearchBar variant="hero" placeholder="Search a company or policy — try &quot;Amazon&quot; or &quot;cancel&quot;" />
        <p class="hero__browse-link"><a href="/companies/">Or browse by company →</a></p>
      </div>
    </div>
  </section>

  <div class="container">

    <!-- Popular Summaries -->
    {popularSummaries.length > 0 && (
      <section>
        <h2 class="section-heading">Popular Summaries</h2>
        <div class="card-grid">
          {popularSummaries.map((item) => (
            <a href={item.href} class="card">
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Popular Companies carousel -->
    <MerchantCarousel />

    <!-- Browse by Category -->
    <section>
      <h2 class="section-heading">Browse by Category</h2>
      <div class="card-grid">
        {categories.map(cat => (
          <a href={cat.href} class="card card--category">
            <h3>{cat.title}</h3>
            <p>{cat.description}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <p>Can't find a policy? Tell us what to decode next.</p>
      <a href="/contact/">Request a Decode &rarr;</a>
    </section>

  </div>
</BaseLayout>
