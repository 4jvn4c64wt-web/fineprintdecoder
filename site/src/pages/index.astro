---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';

const categories = [
  {
    href: '/return-policies/',
    title: 'Return Policies',
    description: 'How long you have, what you need, what gets refunded.',
  },
  {
    href: '/cancellation-policies/',
    title: 'Cancellation Policies',
    description: 'How to actually cancel, what it costs, and how long it takes.',
  },
  {
    href: '/credit-card-agreements/',
    title: 'Credit Card Agreements',
    description: 'Annual fee, APR, foreign transaction fees, and the conditions on the rewards.',
  },
  {
    href: '/warranty-fine-print/',
    title: 'Warranty Fine Print',
    description: 'What is covered, what is excluded, and how to file a claim.',
  },
  {
    href: '/terms-of-service/',
    title: 'Terms of Service',
    description: 'The clauses that matter: arbitration, account termination, content rights.',
  },
];

const popularSummaries = [
  { href: '/return-policies/amazon/', title: 'Amazon Return Policy' },
  { href: '/return-policies/costco/', title: 'Costco Return Policy' },
  { href: '/cancellation-policies/planet-fitness/', title: 'Planet Fitness Cancellation' },
  { href: '/return-policies/target/', title: 'Target Return Policy' },
  { href: '/credit-card-agreements/chase-sapphire-preferred/', title: 'Chase Sapphire Preferred Agreement' },
  { href: '/cancellation-policies/netflix/', title: 'Netflix Cancellation Policy' },
  { href: '/return-policies/best-buy/', title: 'Best Buy Return Policy' },
  { href: '/warranty-fine-print/applecare/', title: 'AppleCare+ Terms' },
];

const recentAdditions = [
  { href: '#', title: 'Coming soon', date: '' },
];
---

<BaseLayout title="We read the fine print so you don't have to">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1>We read the fine print so you don't have to.</h1>
      <p>Plain-English summaries of return policies, cancellation terms, credit card agreements, warranties, and terms of service. Each summary links back to the source document.</p>

      <div class="hero__search">
        <SearchBar variant="hero" placeholder="Search a company or policy — try &quot;Amazon&quot; or &quot;cancel&quot;" />
      </div>
    </div>
  </section>

  <div class="container">

    <!-- Popular Summaries -->
    <section>
      <h2 class="section-heading">Popular Summaries</h2>
      <div class="card-grid">
        {popularSummaries.map(item => (
          <a href={item.href} class="card">
            <h3>{item.title}</h3>
            <p class="placeholder-text">Summary coming soon.</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Browse by Category -->
    <section>
      <h2 class="section-heading">Browse by Category</h2>
      <div class="card-grid">
        {categories.map(cat => (
          <a href={cat.href} class="card card--category">
            <h3>{cat.title}</h3>
            <p>{cat.description}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Recent Additions -->
    <section>
      <h2 class="section-heading">Recently Added</h2>
      <div class="placeholder-notice">
        Policy summaries will appear here as they are published.
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <p>Can't find a policy? Tell us what to decode next.</p>
      <a href="/contact/">Request a Decode &rarr;</a>
    </section>

  </div>
</BaseLayout>
