---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Featured merchant vendors for the homepage grid.
const merchantVendors = await getCollection('merchantVendors', ({ data }) => data.featured);
merchantVendors.sort((a, b) => a.data.displayName.localeCompare(b.data.displayName));

// Most-trafficked scenarios across all merchant vendors (Tier 1 only)
const allScenarios = await getCollection('merchantScenarios', ({ data }) => data.tier === 1);
// Limit homepage to 6 scenarios max so it stays scannable
const featuredScenarios = allScenarios.slice(0, 6).map((s) => {
  const cleanId = s.id.replace(/\.md$/, '');
  const parts = cleanId.split('/');
  const vendor = parts[0];
  const slug = parts[parts.length - 1];
  return {
    href: `/merchants/${vendor}/${slug}/`,
    title: s.data.title,
    summary: s.data.summary,
    vendor: s.data.vendorDisplayName,
  };
});
---

<BaseLayout
  title="We read the agreement so you don't have to"
  description="Plain-English reference on what your payment processor and platform agreements actually say. Built for small business owners who don't want to hire a lawyer to read Stripe's TOS."
>

  <section class="hero">
    <div class="container">
      <h1>We read the agreement so you don't have to.</h1>
      <p>If you run a small business, you signed an agreement with Stripe, Shopify, Square, Toast, or Amazon that you almost certainly didn't read in full. We did. Here's what each one says about the situations that actually affect you — cited to the section, written for non-lawyers, and re-verified on a regular cadence.</p>
      <p class="hero__browse-link"><a href="/merchants/">Browse by vendor →</a></p>
    </div>
  </section>

  <div class="container">

    {featuredScenarios.length > 0 && (
      <section>
        <h2 class="section-heading">Common situations</h2>
        <p>If something on your account broke and you need a real answer:</p>
        <div class="card-grid">
          {featuredScenarios.map((item) => (
            <a href={item.href} class="card">
              <div class="merchant__policy-card-label">{item.vendor}</div>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    {merchantVendors.length > 0 && (
      <section>
        <h2 class="section-heading">Vendors covered</h2>
        <div class="card-grid">
          {merchantVendors.map((v) => (
            <a href={`/merchants/${v.data.vendorSlug}/`} class="card card--category">
              <h3>{v.data.displayName}</h3>
              <p>{v.data.oneSentenceWhat}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <section>
      <h2 class="section-heading">Why this site exists</h2>
      <p>Search Google when a payment processor freezes your account and you'll get three kinds of results: the processor's own help docs (vague by design), competitor blogs that want you to switch processors, and chargeback consultants who want to sell you their service. Nobody is just reading the actual contract carefully and telling you what it says.</p>
      <p>That's what we do. Every claim on this site is cited to a specific section of the agreement. Every page is dated. We re-verify the high-traffic pages every quarter so a stale answer doesn't strand you.</p>
    </section>

    <section class="cta-section">
      <p>Don't see your vendor? Tell us which one to cover next.</p>
      <a href="/contact/">Request a Decode &rarr;</a>
    </section>

  </div>
</BaseLayout>
