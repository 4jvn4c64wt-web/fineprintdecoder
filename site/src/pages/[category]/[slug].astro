---
import { getCollection } from 'astro:content';
import PolicySummaryLayout from '../../layouts/PolicySummaryLayout.astro';

export async function getStaticPaths() {
  const policies = await getCollection('policies');
  return policies.map((entry) => {
    // Astro 5's glob loader sets entry.id to the path relative to the loader's base,
    // typically without the .md extension. Strip it defensively in case behavior shifts.
    const cleanId = entry.id.replace(/\.md$/, '');
    const [category, ...rest] = cleanId.split('/');
    const slug = rest.join('/');
    return {
      params: { category, slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
---

<PolicySummaryLayout entry={entry} />
