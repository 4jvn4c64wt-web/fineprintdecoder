---
import BaseLayout from './BaseLayout.astro';
import { getEntry, render, type CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'merchantScenarios'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;

// Look up the parent vendor entry
const vendor = await getEntry('merchantVendors', data.vendorSlug);

const verifiedFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(new Date(data.lastVerified));

// Stale-content warning
const daysSinceVerified = Math.floor(
  (Date.now() - new Date(data.lastVerified).getTime()) / (1000 * 60 * 60 * 24),
);
const isStale = daysSinceVerified > 90; // Tier 1 cadence for merchant content

const breadcrumbList = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://fineprintdecoder.com/' },
    { '@type': 'ListItem', position: 2, name: 'Merchants', item: 'https://fineprintdecoder.com/merchants/' },
    { '@type': 'ListItem', position: 3, name: data.vendorDisplayName, item: `https://fineprintdecoder.com/merchants/${data.vendorSlug}/` },
    { '@type': 'ListItem', position: 4, name: data.title, item: Astro.url.href },
  ],
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title,
  description: data.summary,
  datePublished: new Date(data.lastVerified).toISOString(),
  dateModified: new Date(data.lastUpdated).toISOString(),
  author: { '@type': 'Organization', name: 'FinePrintDecoder', url: 'https://fineprintdecoder.com/' },
  publisher: { '@type': 'Organization', name: 'FinePrintDecoder', url: 'https://fineprintdecoder.com/' },
  mainEntityOfPage: Astro.url.href,
  about: { '@type': 'Organization', name: data.vendorDisplayName },
};
---

<BaseLayout
  title={data.title}
  description={data.summary}
  structuredData={[articleSchema, breadcrumbList]}
>
  <article class="summary">
    <div class="container summary__container">

      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/merchants/">Merchants</a>
        <span aria-hidden="true">›</span>
        <a href={`/merchants/${data.vendorSlug}/`}>{data.vendorDisplayName}</a>
        <span aria-hidden="true">›</span>
        <span>{data.title}</span>
      </nav>

      <header class="summary__header">
        <h1>{data.title}</h1>
        <div class="summary__meta">
          <span class="summary__verified">Last verified <strong>{verifiedFmt}</strong></span>
          {vendor && (
            <a class="summary__source-link summary__source-link--overview" href={`/merchants/${vendor.data.vendorSlug}/`}>
              {vendor.data.displayName} merchant overview →
            </a>
          )}
        </div>
        {isStale && (
          <div class="staleness-banner" role="status">
            This summary hasn't been re-verified in over 90 days. The platform may have changed its terms. Always check the source documents for current terms.
          </div>
        )}
      </header>

      <section class="callout callout--bottom-line" aria-label="The bottom line">
        <h2 class="callout__label">The Bottom Line</h2>
        <p class="callout__body">{data.bottomLine}</p>
      </section>

      <section class="key-facts" aria-label="Key facts">
        <h2 class="section-label">Key Facts</h2>
        <dl class="key-facts__list">
          {data.keyFacts.map((kf) => (
            <div class="key-facts__row">
              <dt>{kf.label}</dt>
              <dd>
                <span set:html={kf.value} />
                {kf.citation && (
                  <span class="key-facts__citation"> <em>({kf.citation})</em></span>
                )}
              </dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="how-to" aria-label="What to do">
        <h2 class="section-label">What to Do</h2>
        <ol class="how-to__steps">
          {data.whatToDo.map((step) => (
            <li>{step}</li>
          ))}
        </ol>
      </section>

      {data.pitfalls.length > 0 && (
        <section class="callout callout--watch-out" aria-label="Common pitfalls">
          <h2 class="callout__label">Common Pitfalls</h2>
          <ul class="watch-out__list">
            {data.pitfalls.map((item) => (
              <li>
                <strong class="watch-out__headline">{item.headline}</strong>
                <span class="watch-out__detail"> {item.detail}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      <details id="full-breakdown" class="collapsible">
        <summary>Read the full breakdown</summary>
        <div class="collapsible__content prose">
          <Content />
        </div>
      </details>

      {data.whatChanged.length > 0 && (
        <details class="collapsible">
          <summary>What changed</summary>
          <div class="collapsible__content">
            <ul class="changelog">
              {data.whatChanged.map((wc) => (
                <li>
                  <time datetime={new Date(wc.date).toISOString()}>
                    {new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(new Date(wc.date))}
                  </time>
                  <span>{wc.note}</span>
                </li>
              ))}
            </ul>
          </div>
        </details>
      )}

      <aside class="summary__disclaimer">
        <p>
          This is a plain-English summary of one provision of {data.vendorDisplayName}'s publicly available agreement, compiled from the documents linked in the frontmatter. It is not legal advice. Always refer to the
          {data.sourceUrls.length > 0 && (
            <Fragment>
              {' '}
              <a href={data.sourceUrls[0]} target="_blank" rel="noopener">original document</a>
            </Fragment>
          )}
          {' '}for the authoritative and current terms. This summary was produced with AI assistance and reviewed before publication. If you find an error or notice a change,
          <a href="/contact/"> let us know</a>.
        </p>
      </aside>

    </div>
  </article>
</BaseLayout>
