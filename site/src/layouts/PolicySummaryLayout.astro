---
import BaseLayout from './BaseLayout.astro';
import { render, getEntry, type CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'policies'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;

// Look up the parent vendor entry so we can link to the merchant overview.
// Returns undefined if there's no vendor entry yet for this slug (rare; will warn).
const vendor = await getEntry('vendors', data.vendorSlug);

// Map category slug → human-readable category label (used in breadcrumb)
const categoryLabel: Record<string, string> = {
  'return-policies': 'Return Policies',
  'cancellation-policies': 'Cancellation Policies',
  'credit-card-agreements': 'Credit Card Agreements',
  'warranty-fine-print': 'Warranty Fine Print',
  'terms-of-service': 'Terms of Service',
};

const category = categoryLabel[data.category] ?? data.category;

// Stale-content banner — see business-plan §5.4
const stalenessThresholdDays = 365;
const daysSinceVerified = Math.floor(
  (Date.now() - new Date(data.lastVerified).getTime()) / (1000 * 60 * 60 * 24)
);
const isStale = daysSinceVerified > stalenessThresholdDays;

// Format the verified date as "Month DD, YYYY"
const verifiedFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(new Date(data.lastVerified));

// Legal fine print rows (skip undefined entries)
const legalRows: { label: string; value: string }[] = [];
if (data.legalFinePrint) {
  const lp = data.legalFinePrint;
  if (lp.governingLaw) legalRows.push({ label: 'Governing law', value: lp.governingLaw });
  if (lp.disputeVenue) legalRows.push({ label: 'Dispute venue', value: lp.disputeVenue });
  if (lp.juryTrial) legalRows.push({ label: 'Jury trial', value: lp.juryTrial });
  if (lp.arbitration) legalRows.push({ label: 'Arbitration / class action', value: lp.arbitration });
  if (lp.accountTermination) legalRows.push({ label: 'Account termination', value: lp.accountTermination });
  if (lp.liabilityCap) legalRows.push({ label: 'Liability cap', value: lp.liabilityCap });
  if (lp.privacyHighLevel) legalRows.push({ label: 'Privacy & data use', value: lp.privacyHighLevel });
}

const description = data.summary;

// ---------------------------------------------------------------------------
// Key Fact rendering helpers
// ---------------------------------------------------------------------------

// Render the <dd> content for a single key fact row.
// Handles three cases:
//   1. returnWindows array → mini sub-table (only when 2+ windows)
//   2. ineligibleItems string → truncated at ~120 chars with "see more →" anchor
//   3. plain value string → rendered as HTML (supports inline markup via set:html)
//
// Returns an object with { type, ...data } so the template can branch cleanly.

const INELIGIBLE_CAP = 120; // characters before truncation

function truncateIneligible(full: string): { display: string; truncated: boolean } {
  if (full.length <= INELIGIBLE_CAP) return { display: full, truncated: false };
  const slice = full.slice(0, INELIGIBLE_CAP);
  const lastComma = slice.lastIndexOf(',');
  // Cut at last comma, then trim trailing whitespace and punctuation
  const raw = lastComma > 0 ? slice.slice(0, lastComma) : slice;
  const display = raw.replace(/[,\s]+$/, '');
  return { display, truncated: true };
}
---

<BaseLayout title={data.title} description={description}>
  <article class="summary">
    <div class="container summary__container">

      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <a href={`/${data.category}/`}>{category}</a>
        <span aria-hidden="true">›</span>
        <span>{data.company}</span>
      </nav>

      <!-- Title + meta -->
      <header class="summary__header">
        <h1>{data.title}</h1>
        <div class="summary__meta">
          <span class="summary__verified">Last verified <strong>{verifiedFmt}</strong></span>
          <a class="summary__source-link" href={data.sourceUrl} target="_blank" rel="noopener">
            Read the official policy →
          </a>
          {vendor && (
            <a class="summary__source-link summary__source-link--overview" href={`/${vendor.data.vendorSlug}/`}>
              Read the {vendor.data.displayName} overview →
            </a>
          )}
        </div>
        {isStale && (
          <div class="staleness-banner" role="status">
            This summary hasn't been re-verified in over a year. The company may have changed its policy. Always check the
            <a href={data.sourceUrl} target="_blank" rel="noopener"> original document</a> for the current terms.
          </div>
        )}
      </header>

      <!-- Bottom Line -->
      <section class="callout callout--bottom-line" aria-label="The bottom line">
        <h2 class="callout__label">The Bottom Line</h2>
        <p class="callout__body">{data.bottomLine}</p>
      </section>

      {/* ============================================================
          ABOVE-THE-FOLD: Key Facts + How To.
          Branches on data shape:
          - data.channels populated → multi-channel mode: render tabs + card containing
            the active channel's Key Facts and How To. First channel is the default.
          - data.keyFacts populated → single-channel mode: render Key Facts and How To
            as before.
          The content schema enforces exactly one of these two is populated.
          ============================================================ */}

      {data.channels && data.channels.length > 0 ? (
        <section class="channel-tabs" aria-label="Choose how you bought this item">
          <p class="channel-tabs__intro">How did you get this item?</p>

          <div class="channel-tabs__viewport">
            <button
              type="button"
              class="channel-tabs__arrow channel-tabs__arrow--prev"
              aria-label="Previous channel"
              data-channel-arrow="prev"
              hidden
            >
              ‹
            </button>

            <div class="channel-tabs__tablist" role="tablist" aria-label="Purchase channel">
              {data.channels.map((ch, i) => (
                <button
                  type="button"
                  role="tab"
                  id={`channel-tab-${ch.slug}`}
                  aria-controls={`channel-panel-${ch.slug}`}
                  aria-selected={i === 0 ? 'true' : 'false'}
                  tabindex={i === 0 ? 0 : -1}
                  class={`channel-tabs__tab${i === 0 ? ' is-active' : ''}`}
                  data-channel-tab={ch.slug}
                  data-channel-label={ch.label}
                >
                  {ch.label}
                </button>
              ))}
            </div>

            <button
              type="button"
              class="channel-tabs__arrow channel-tabs__arrow--next"
              aria-label="Next channel"
              data-channel-arrow="next"
            >
              ›
            </button>
          </div>

          <div class="channel-tabs__panels">
            {data.channels.map((ch, i) => (
              <div
                role="tabpanel"
                id={`channel-panel-${ch.slug}`}
                aria-labelledby={`channel-tab-${ch.slug}`}
                class={`channel-tabs__panel${i === 0 ? ' is-active' : ''}`}
                data-channel-panel={ch.slug}
                data-channel-label={ch.label}
                hidden={i !== 0}
              >
                <h3 class="channel-tabs__panel-label">Key Facts</h3>
                <dl class="key-facts__list">
                  {ch.keyFacts.map((kf) => {
                    const ineligible = kf.ineligibleItems ? truncateIneligible(kf.ineligibleItems) : null;
                    return (
                      <div class="key-facts__row">
                        <dt>{kf.label}</dt>
                        <dd>
                          {kf.returnWindows && kf.returnWindows.length >= 2 ? (
                            <table class="return-window-table" aria-label="Return windows by category">
                              <tbody>
                                {kf.returnWindows.map((rw) => (
                                  <tr>
                                    <td class="return-window-table__items">{rw.items}</td>
                                    <td class="return-window-table__window">{rw.window}</td>
                                  </tr>
                                ))}
                              </tbody>
                            </table>
                          ) : ineligible ? (
                            <span class="ineligible-items">
                              <span class="ineligible-items__list">{ineligible.display}</span>
                              {ineligible.truncated && (
                                <a href="#full-breakdown" class="see-more-link">See full list →</a>
                              )}
                            </span>
                          ) : (
                            <Fragment set:html={kf.value} />
                          )}
                        </dd>
                      </div>
                    );
                  })}
                </dl>

                {ch.howTo && ch.howTo.length > 0 && (
                  <div class="channel-tabs__howto">
                    <h3 class="channel-tabs__panel-label">How To</h3>
                    <ol class="how-to__steps">
                      {ch.howTo.map((step) => (
                        <li>{step}</li>
                      ))}
                    </ol>
                  </div>
                )}
              </div>
            ))}
          </div>

          {/* No-JS fallback: tablist + arrows are hidden, all panels show stacked
              with their channel label as a heading. */}
          <noscript>
            <style>
              {`
                .channel-tabs__viewport { display: none; }
                .channel-tabs__panel[hidden] { display: block !important; }
                .channel-tabs__panel + .channel-tabs__panel {
                  margin-top: 1.5rem;
                  padding-top: 1.25rem;
                  border-top: 1px dashed var(--color-border);
                }
                .channel-tabs__panel::before {
                  content: "For " attr(data-channel-label) " purchases";
                  display: block;
                  font-size: 0.82rem;
                  font-weight: 700;
                  text-transform: uppercase;
                  letter-spacing: 0.06em;
                  color: var(--color-primary-dark);
                  margin-bottom: 0.75rem;
                  padding-bottom: 0.5rem;
                  border-bottom: 1px solid var(--color-border);
                }
              `}
            </style>
          </noscript>
        </section>
      ) : (
        <>
          {/* Single-channel mode: standard Key Facts + How To. */}
          {data.keyFacts && data.keyFacts.length > 0 && (
            <section class="key-facts" aria-label="Key facts">
              <h2 class="section-label">Key Facts</h2>
              <dl class="key-facts__list">
                {data.keyFacts.map((kf) => {
                  const ineligible = kf.ineligibleItems ? truncateIneligible(kf.ineligibleItems) : null;
                  return (
                    <div class="key-facts__row">
                      <dt>{kf.label}</dt>
                      <dd>
                        {kf.returnWindows && kf.returnWindows.length >= 2 ? (
                          <table class="return-window-table" aria-label="Return windows by category">
                            <tbody>
                              {kf.returnWindows.map((rw) => (
                                <tr>
                                  <td class="return-window-table__window">{rw.window}</td>
                                  <td class="return-window-table__items">{rw.items}</td>
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        ) : ineligible ? (
                          <span>
                            {ineligible.display}
                            {ineligible.truncated && (
                              <Fragment>
                                {', '}
                                <a href="#full-breakdown" class="see-more-link">see more →</a>
                              </Fragment>
                            )}
                          </span>
                        ) : (
                          <Fragment set:html={kf.value} />
                        )}
                      </dd>
                    </div>
                  );
                })}
              </dl>
            </section>
          )}

          {data.howTo && data.howTo.length > 0 && (
            <section class="how-to" aria-label={`How to ${data.policyType.toLowerCase().includes('cancel') ? 'cancel' : data.policyType.toLowerCase().includes('return') ? 'return' : 'use this policy'}`}>
              <h2 class="section-label">How To</h2>
              <ol class="how-to__steps">
                {data.howTo.map((step) => (
                  <li>{step}</li>
                ))}
              </ol>
            </section>
          )}
        </>
      )}

      <!-- Watch Out For -->
      {data.watchOutFor.length > 0 && (
        <section class="callout callout--watch-out" aria-label="Things to watch out for">
          <h2 class="callout__label">Watch Out For</h2>
          <ul class="watch-out__list">
            {data.watchOutFor.map((item) => (
              <li>
                <strong class="watch-out__headline">{item.headline}</strong>
                <span class="watch-out__detail"> {item.detail}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- Full Breakdown (collapsed by default) -->
      <details id="full-breakdown" class="collapsible">
        <summary>Read the full breakdown</summary>
        <div class="collapsible__content prose">
          <Content />
        </div>
      </details>

      <!-- Legal Fine Print (collapsed by default) -->
      {legalRows.length > 0 && (
        <details class="collapsible">
          <summary>Legal fine print (venue, arbitration, liability)</summary>
          <div class="collapsible__content">
            <dl class="legal-list">
              {legalRows.map((row) => (
                <div class="legal-list__row">
                  <dt>{row.label}</dt>
                  <dd>{row.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        </details>
      )}

      <!-- What Changed (collapsed) -->
      {data.whatChanged.length > 0 && (
        <details class="collapsible">
          <summary>What changed</summary>
          <div class="collapsible__content">
            <ul class="changelog">
              {data.whatChanged.map((entry) => (
                <li>
                  <time datetime={new Date(entry.date).toISOString()}>
                    {new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(new Date(entry.date))}
                  </time>
                  <span>{entry.note}</span>
                </li>
              ))}
            </ul>
          </div>
        </details>
      )}

      <!-- Disclaimer (includes the source link inline; no separate Original Document section) -->
      <aside class="summary__disclaimer">
        <p>
          This is a plain-English summary of {data.company}'s {data.policyType.toLowerCase()},
          compiled from the publicly available document. It is not legal advice. Companies change
          their terms; this summary may not reflect the latest version. Always refer to the
          <a href={data.sourceUrl} target="_blank" rel="noopener">original document</a>
          {data.sourceUrlsAdditional.length > 0 && (
            <Fragment>
              {' '}(and {data.sourceUrlsAdditional.map((url, i) => (
                <Fragment>
                  {i > 0 && ', '}
                  <a href={url} target="_blank" rel="noopener">related source {i + 1}</a>
                </Fragment>
              ))})
            </Fragment>
          )}
          {' '}for the authoritative and current terms. This summary was produced with AI assistance
          and reviewed before publication. If you find an error or notice a change,
          <a href="/contact/">let us know</a>.
        </p>
      </aside>

    </div>
  </article>

  {/* Progressive enhancement for the channel tabs.
      - Wires up tab clicks + the prev/next arrow buttons to swap which panel is visible.
      - Keyboard support: ArrowLeft / ArrowRight cycle tabs; Home / End jump to first / last.
      - Inactive panels carry the [hidden] attribute (set in the layout); script swaps it.
      - No-JS fallback is handled by a <noscript><style> block in the layout, not here.
      - Safe to ship on every policy page — script is inert when no tablist exists. */}
  {/* "See more →" links open the full-breakdown <details> if it's collapsed. */}
  <script is:inline>
    (function () {
      document.querySelectorAll('.see-more-link').forEach(function (link) {
        link.addEventListener('click', function () {
          var el = document.getElementById('full-breakdown');
          if (el) el.open = true;
        });
      });
    })();
  </script>

  {data.channels && data.channels.length > 0 && (
    <script is:inline>
      (function () {
        var tablist = document.querySelector('.channel-tabs__tablist');
        if (!tablist) return;

        var tabs = Array.prototype.slice.call(tablist.querySelectorAll('[role="tab"]'));
        var panels = Array.prototype.slice.call(document.querySelectorAll('[role="tabpanel"]'));
        var prevArrow = document.querySelector('[data-channel-arrow="prev"]');
        var nextArrow = document.querySelector('[data-channel-arrow="next"]');

        function currentIndex() {
          for (var i = 0; i < tabs.length; i++) {
            if (tabs[i].getAttribute('aria-selected') === 'true') return i;
          }
          return 0;
        }

        function updateArrows(idx) {
          if (prevArrow) {
            if (idx <= 0) prevArrow.setAttribute('hidden', '');
            else prevArrow.removeAttribute('hidden');
          }
          if (nextArrow) {
            if (idx >= tabs.length - 1) nextArrow.setAttribute('hidden', '');
            else nextArrow.removeAttribute('hidden');
          }
        }

        function activate(targetIdx, focus) {
          if (targetIdx < 0 || targetIdx >= tabs.length) return;
          var targetTab = tabs[targetIdx];
          tabs.forEach(function (tab) {
            var isActive = tab === targetTab;
            tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
            tab.setAttribute('tabindex', isActive ? '0' : '-1');
            tab.classList.toggle('is-active', isActive);
          });
          var targetSlug = targetTab.getAttribute('data-channel-tab');
          panels.forEach(function (panel) {
            var isActive = panel.getAttribute('data-channel-panel') === targetSlug;
            panel.classList.toggle('is-active', isActive);
            if (isActive) {
              panel.removeAttribute('hidden');
            } else {
              panel.setAttribute('hidden', '');
            }
          });
          updateArrows(targetIdx);
          if (focus) targetTab.focus();
        }

        tabs.forEach(function (tab, idx) {
          tab.addEventListener('click', function () {
            activate(idx, false);
          });
          tab.addEventListener('keydown', function (event) {
            var nextIdx = null;
            if (event.key === 'ArrowRight') nextIdx = (idx + 1) % tabs.length;
            else if (event.key === 'ArrowLeft') nextIdx = (idx - 1 + tabs.length) % tabs.length;
            else if (event.key === 'Home') nextIdx = 0;
            else if (event.key === 'End') nextIdx = tabs.length - 1;
            if (nextIdx !== null) {
              event.preventDefault();
              activate(nextIdx, true);
            }
          });
        });

        if (prevArrow) {
          prevArrow.addEventListener('click', function () {
            activate(currentIndex() - 1, false);
          });
        }
        if (nextArrow) {
          nextArrow.addEventListener('click', function () {
            activate(currentIndex() + 1, false);
          });
        }

        // Initialize arrow visibility for the default tab (index 0).
        updateArrows(0);
      })();
    </script>
  )}

</BaseLayout>
